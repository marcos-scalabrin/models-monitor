# Artificial Analysis (paid plan) — required for real benchmark data.
AA_API_KEY=

# OpenRouter — optional. Public endpoint works without a key; a key only
# enriches usage context.
OPENROUTER_API_KEY=

# Force fixtures (offline mode). Leave empty/false to fetch live.
USE_FIXTURES=false

# Filtering thresholds
MAX_INPUT_COST_PER_1M=100
MIN_INTELLIGENCE_SCORE=0

# Cache TTL for joined data (seconds). Default 6h.
CACHE_TTL_SECONDS=21600
